{% extends "base.html" %}
{% block title %}Design Campaign - SendBaba{% endblock %}
{% block content %}
<style>
/* Editor Layout */
.editor-wrapper { display: flex; height: calc(100vh - 70px); }
.editor-sidebar { width: 320px; background: #1e293b; border-right: 1px solid #334155; overflow-y: auto; }
.editor-canvas { flex: 1; background: #0f172a; overflow-y: auto; padding: 40px; }
.editor-properties { width: 320px; background: #1e293b; border-left: 1px solid #334155; overflow-y: auto; }

/* Email Canvas */
.email-canvas { 
    max-width: 650px; 
    margin: 0 auto; 
    background: white; 
    min-height: 600px; 
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    border-radius: 8px;
    overflow: hidden;
}

/* Blocks */
.block-item {
    background: #334155;
    padding: 16px;
    margin-bottom: 12px;
    border-radius: 8px;
    cursor: grab;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 12px;
}
.block-item:hover {
    background: #475569;
    transform: translateY(-2px);
}
.block-item:active { cursor: grabbing; }
.block-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-center;
    border-radius: 6px;
    font-size: 20px;
}

/* Editable Sections */
.editable-section {
    position: relative;
    cursor: text;
    transition: all 0.2s;
}
.editable-section:hover {
    outline: 2px dashed #10b981;
    outline-offset: 4px;
}
.editable-section:focus {
    outline: 2px solid #10b981;
    outline-offset: 4px;
}

.editable-button {
    position: relative;
}
.editable-button:hover {
    opacity: 0.9;
    cursor: pointer;
}

/* Drop Zone */
.drop-zone {
    min-height: 100px;
    border: 2px dashed #475569;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    margin: 20px;
    padding: 40px;
    transition: all 0.2s;
}
.drop-zone.drag-over {
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
}

/* Tabs */
.tab-btn {
    padding: 12px 24px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 500;
}
.tab-btn.active {
    color: #10b981;
    border-bottom-color: #10b981;
}
.tab-content { display: none; }
.tab-content.active { display: block; }
</style>

<div class="bg-slate-800 border-b border-slate-700 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <a href="/dashboard/campaigns" class="text-white hover:text-gray-300 transition">
            <i class="fas fa-arrow-left text-xl"></i>
        </a>
        <div>
            <h1 class="text-white font-bold text-lg" id="campaignNameDisplay">{{ campaign_name }}</h1>
            <p class="text-gray-400 text-sm">Campaign Designer</p>
        </div>
    </div>
    
    <div class="flex items-center gap-3">
        <button onclick="previewEmail()" class="px-6 py-2.5 bg-slate-700 hover:bg-slate-600 text-white rounded-lg transition font-medium flex items-center gap-2">
            <i class="fas fa-eye"></i> Preview
        </button>
        <button onclick="saveDraft()" id="saveDraftBtn" class="px-6 py-2.5 bg-slate-700 hover:bg-slate-600 text-white rounded-lg transition font-medium flex items-center gap-2">
            <i class="fas fa-save"></i> Save draft
        </button>
        <button onclick="showSendModal()" class="px-8 py-2.5 bg-green-500 hover:bg-green-600 text-white rounded-lg transition font-bold shadow-lg flex items-center gap-2">
            <i class="fas fa-paper-plane"></i> Send
        </button>
    </div>
</div>

<div class="editor-wrapper">
    <!-- Left Sidebar -->
    <div class="editor-sidebar">
        <div class="p-6">
            <div class="flex border-b border-slate-700 mb-6">
                <button class="tab-btn active" onclick="switchTab('blocks')">Blocks</button>
                <button class="tab-btn" onclick="switchTab('settings')">Settings</button>
            </div>

            <!-- Blocks Tab -->
            <div id="blocks-tab" class="tab-content active">
                <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Drag & Drop Blocks</h3>
                <div class="space-y-3">
                    <div class="block-item" draggable="true" data-block="heading">
                        <div class="block-icon bg-green-500"><i class="fas fa-heading text-white"></i></div>
                        <div>
                            <div class="text-white font-medium">Heading</div>
                            <div class="text-gray-400 text-xs">Add a title</div>
                        </div>
                    </div>
                    <div class="block-item" draggable="true" data-block="text">
                        <div class="block-icon bg-blue-500"><i class="fas fa-align-left text-white"></i></div>
                        <div>
                            <div class="text-white font-medium">Text</div>
                            <div class="text-gray-400 text-xs">Add paragraph</div>
                        </div>
                    </div>
                    <div class="block-item" draggable="true" data-block="button">
                        <div class="block-icon bg-purple-500"><i class="fas fa-hand-pointer text-white"></i></div>
                        <div>
                            <div class="text-white font-medium">Button</div>
                            <div class="text-gray-400 text-xs">Call to action</div>
                        </div>
                    </div>
                    <div class="block-item" draggable="true" data-block="image">
                        <div class="block-icon bg-yellow-500"><i class="fas fa-image text-white"></i></div>
                        <div>
                            <div class="text-white font-medium">Image</div>
                            <div class="text-gray-400 text-xs">Add photo</div>
                        </div>
                    </div>
                    <div class="block-item" draggable="true" data-block="divider">
                        <div class="block-icon bg-gray-500"><i class="fas fa-grip-lines text-white"></i></div>
                        <div>
                            <div class="text-white font-medium">Divider</div>
                            <div class="text-gray-400 text-xs">Section break</div>
                        </div>
                    </div>
                    <div class="block-item" draggable="true" data-block="spacer">
                        <div class="block-icon bg-indigo-500"><i class="fas fa-arrows-alt-v text-white"></i></div>
                        <div>
                            <div class="text-white font-medium">Spacer</div>
                            <div class="text-gray-400 text-xs">Add space</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Settings Tab -->
            <div id="settings-tab" class="tab-content">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-300 mb-2">Campaign Name</label>
                        <input type="text" id="campaignName" value="{{ campaign_name }}" class="w-full px-4 py-2.5 bg-slate-700 border border-slate-600 rounded-lg text-white focus:ring-2 focus:ring-green-500 focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-300 mb-2">Subject Line</label>
                        <input type="text" id="emailSubject" placeholder="Your email subject" class="w-full px-4 py-2.5 bg-slate-700 border border-slate-600 rounded-lg text-white focus:ring-2 focus:ring-green-500">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-300 mb-2">Preview Text</label>
                        <textarea id="previewText" rows="3" placeholder="Inbox preview..." class="w-full px-4 py-2.5 bg-slate-700 border border-slate-600 rounded-lg text-white focus:ring-2 focus:ring-green-500"></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Center Canvas -->
    <div class="editor-canvas">
        <div class="email-canvas" id="emailCanvas">
            {% if template_html %}
            {{ template_html|safe }}
            {% else %}
            <div class="drop-zone" id="mainDropZone">
                <div class="text-center">
                    <i class="fas fa-mouse-pointer text-5xl mb-4"></i>
                    <p class="text-lg font-medium">Drag blocks here to start</p>
                    <p class="text-sm mt-2">Or choose a template from the gallery</p>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="editor-properties">
        <div class="p-6">
            <h3 class="text-white font-bold text-lg mb-6">Campaign Info</h3>
            <div class="space-y-4">
                <div class="bg-slate-700 rounded-lg p-4">
                    <div class="text-gray-400 text-sm mb-1">Recipients</div>
                    <div class="text-white font-bold text-3xl">{{ "{:,}".format(contacts_count) }}</div>
                    <div class="text-gray-400 text-xs mt-1">Active contacts</div>
                </div>

                {% if domains %}
                <div class="bg-slate-700 rounded-lg p-4">
                    <div class="text-gray-400 text-sm mb-2">From Domain</div>
                    <select id="fromDomain" class="w-full bg-slate-600 text-white px-3 py-2 rounded border border-slate-500 focus:ring-2 focus:ring-green-500">
                        {% for domain in domains %}
                        <option value="{{ domain.domain_name }}">{{ domain.domain_name }}</option>
                        {% endfor %}
                    </select>
                </div>
                {% endif %}

                <div class="bg-slate-700 rounded-lg p-4">
                    <div class="text-gray-400 text-sm mb-1">Status</div>
                    <div class="inline-flex items-center gap-2 bg-yellow-500 text-yellow-900 px-3 py-1 rounded-full text-sm font-semibold">
                        <i class="fas fa-circle text-xs"></i> Draft
                    </div>
                </div>
            </div>

            <div class="mt-6 p-4 bg-blue-500/10 border border-blue-500/30 rounded-lg">
                <div class="text-blue-400 font-semibold mb-2 flex items-center gap-2">
                    <i class="fas fa-lightbulb"></i> Pro Tip
                </div>
                <p class="text-gray-300 text-sm">Click any text to edit it directly. Drag blocks to rearrange.</p>
            </div>
        </div>
    </div>
</div>

<!-- Send Modal -->
<div id="sendModal" class="hidden fixed inset-0 bg-black/75 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">Ready to send?</h3>
        <p class="text-gray-600 mb-6">Campaign will be sent to <strong class="text-gray-900">{{ "{:,}".format(contacts_count) }} contacts</strong></p>
        
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-3">
                <i class="fas fa-info-circle text-blue-500 text-xl mt-0.5"></i>
                <div>
                    <p class="text-blue-900 font-semibold text-sm mb-1">Want to test first?</p>
                    <p class="text-blue-700 text-sm">Send a test email to yourself before sending to all contacts</p>
                </div>
            </div>
        </div>
        
        <div class="flex gap-3">
            <button onclick="closeSendModal()" class="flex-1 px-6 py-3 border-2 border-gray-300 rounded-lg hover:bg-gray-50 font-semibold transition">
                Cancel
            </button>
            <button onclick="showTestModal()" class="flex-1 px-6 py-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600 font-semibold transition">
                <i class="fas fa-flask mr-2"></i>Send Test
            </button>
            <button onclick="sendCampaign()" class="flex-1 bg-green-500 text-white px-6 py-3 rounded-lg hover:bg-green-600 font-bold transition">
                Send Now
            </button>
        </div>
    </div>
</div>

<!-- Test Email Modal -->
<div id="testModal" class="hidden fixed inset-0 bg-black/75 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">Send Test Email</h3>
        <p class="text-gray-600 mb-6">Preview how your email will look in the inbox</p>
        
        <div class="mb-6">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Send test to:</label>
            <input type="email" id="testEmail" placeholder="your.email@example.com" value="{{ current_user.email }}" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <p class="text-xs text-gray-500 mt-2">The test email will have [TEST] prefix in the subject</p>
        </div>
        
        <div class="flex gap-3">
            <button onclick="closeTestModal()" class="flex-1 px-6 py-3 border-2 border-gray-300 rounded-lg hover:bg-gray-50 font-semibold transition">
                Cancel
            </button>
            <button onclick="sendTestEmail()" id="sendTestBtn" class="flex-1 bg-blue-500 text-white px-6 py-3 rounded-lg hover:bg-blue-600 font-bold transition">
                <i class="fas fa-paper-plane mr-2"></i>Send Test
            </button>
        </div>
    </div>
</div>

<script>
const CAMPAIGN_ID = '{{ campaign_id }}';
let draggedBlock = null;

// Tab switching
function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById(tab + '-tab').classList.add('active');
}

// Drag and drop
document.querySelectorAll('.block-item').forEach(item => {
    item.addEventListener('dragstart', (e) => {
        draggedBlock = e.target.dataset.block;
        e.target.style.opacity = '0.5';
    });
    item.addEventListener('dragend', (e) => {
        e.target.style.opacity = '1';
    });
});

const canvas = document.getElementById('emailCanvas');
const mainDropZone = document.getElementById('mainDropZone');

if (mainDropZone) {
    mainDropZone.addEventListener('dragover', handleDragOver);
    mainDropZone.addEventListener('drop', handleDrop);
}

canvas.addEventListener('dragover', handleDragOver);
canvas.addEventListener('drop', handleDrop);

function handleDragOver(e) {
    e.preventDefault();
    e.currentTarget.classList.add('drag-over');
}

function handleDrop(e) {
    e.preventDefault();
    e.currentTarget.classList.remove('drag-over');
    
    if (mainDropZone) mainDropZone.remove();
    addBlock(draggedBlock);
}

function addBlock(type) {
    const blocks = {
        heading: '<div class="editable-section" contenteditable="true" style="padding: 20px; font-size: 32px; font-weight: bold; color: #1e293b;">Click to edit heading</div>',
        text: '<div class="editable-section" contenteditable="true" style="padding: 20px; font-size: 16px; line-height: 1.6; color: #475569;">Click to edit this text. You can write anything here and format it as needed.</div>',
        button: '<div style="padding: 20px; text-align: center;"><a href="#" class="editable-button" contenteditable="true" style="display: inline-block; background: #10b981; color: white; padding: 15px 40px; text-decoration: none; border-radius: 8px; font-weight: bold;">Click Here</a></div>',
        image: '<div style="padding: 20px; text-align: center;"><img src="https://via.placeholder.com/600x300/10b981/FFFFFF?text=Click+to+Edit" style="max-width: 100%; border-radius: 8px; cursor: pointer;" onclick="changeImage(this)" class="editable-section"></div>',
        divider: '<div style="padding: 20px;"><hr style="border: none; border-top: 2px solid #e2e8f0; margin: 0;"></div>',
        spacer: '<div style="height: 40px;"></div>'
    };
    
    const div = document.createElement('div');
    div.innerHTML = blocks[type];
    canvas.appendChild(div.firstChild);
}

function changeImage(img) {
    const url = prompt('Enter image URL:', img.src);
    if (url) img.src = url;
}

async function saveDraft() {
    const btn = document.getElementById('saveDraftBtn');
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
    
    try {
        const response = await fetch('/dashboard/campaigns/api/save-draft', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                campaign_id: CAMPAIGN_ID,
                name: document.getElementById('campaignName').value,
                subject: document.getElementById('emailSubject').value,
                html: canvas.innerHTML
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            btn.innerHTML = '<i class="fas fa-check"></i> Saved!';
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }, 2000);
        } else {
            alert('Error: ' + data.error);
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    } catch (error) {
        alert('Network error');
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

function previewEmail() {
    const win = window.open('', 'Preview', 'width=800,height=600');
    win.document.write(canvas.innerHTML);
    win.document.close();
}

function showSendModal() {
    document.getElementById('sendModal').classList.remove('hidden');
}

function closeSendModal() {
    document.getElementById('sendModal').classList.add('hidden');
}

function showTestModal() {
    document.getElementById('sendModal').classList.add('hidden');
    document.getElementById('testModal').classList.remove('hidden');
}

function closeTestModal() {
    document.getElementById('testModal').classList.add('hidden');
    document.getElementById('sendModal').classList.remove('hidden');
}

async function sendTestEmail() {
    const btn = document.getElementById('sendTestBtn');
    const testEmail = document.getElementById('testEmail').value.trim();
    const subject = document.getElementById('emailSubject').value || 'Test Email';
    
    if (!testEmail || !testEmail.includes('@')) {
        alert('Please enter a valid email address');
        return;
    }
    
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Sending...';
    
    try {
        const response = await fetch('/dashboard/campaigns/api/send-test', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                test_email: testEmail,
                subject: subject,
                html: canvas.innerHTML
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            btn.innerHTML = '<i class="fas fa-check mr-2"></i>Sent!';
            setTimeout(() => {
                closeTestModal();
                btn.innerHTML = originalText;
                btn.disabled = false;
                alert(`✅ Test email sent to ${testEmail}!\n\nCheck your inbox to preview how it looks.`);
            }, 1500);
        } else {
            alert('Error: ' + data.error);
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    } catch (error) {
        alert('Network error');
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

async function sendCampaign() {
    await saveDraft();
    
    try {
        const response = await fetch('/dashboard/campaigns/api/send', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({campaign_id: CAMPAIGN_ID})
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('✅ Campaign sent successfully!');
            window.location.href = '/dashboard/campaigns';
        } else {
            alert('Error: ' + data.error);
        }
    } catch (error) {
        alert('Network error');
    }
}

// Update display name
document.getElementById('campaignName')?.addEventListener('input', (e) => {
    document.getElementById('campaignNameDisplay').textContent = e.target.value;
});
</script>
{% endblock %}
