<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SendBaba{% endblock %}</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom Styles -->
    <style>
        .sidebar-link {
            transition: all 0.2s ease;
        }
        .sidebar-link:hover {
            background: rgba(139, 92, 246, 0.1);
            border-left: 3px solid #8b5cf6;
        }
        .sidebar-link.active {
            background: rgba(139, 92, 246, 0.15);
            border-left: 3px solid #8b5cf6;
            color: #8b5cf6;
        }
        .sidebar-group {
            margin-bottom: 24px;
        }
        .sidebar-group-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #9ca3af;
            padding: 0 20px;
            margin-bottom: 8px;
        }
        .badge {
            font-size: 9px;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .badge-new {
            background: #10b981;
            color: white;
        }
        .badge-pro {
            background: #f59e0b;
            color: white;
        }
    </style>
</head>
<body class="bg-gray-50">
    
    <!-- Main Container -->
    <div class="flex h-screen overflow-hidden">
        
        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-gray-200 overflow-y-auto">
            
            <!-- Logo -->
            <div class="p-6 border-b border-gray-200">
                <a href="/dashboard" class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-purple-600 to-purple-800 rounded-xl flex items-center justify-center">
                        <span class="text-white text-xl font-bold">S</span>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-gray-900">SendBaba</h1>
                        <p class="text-xs text-gray-500">Email Platform</p>
                    </div>
                </a>
            </div>
            
            <!-- Navigation -->
            <nav class="p-4">
                
                <!-- Main Section -->
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Main</div>
                    
                    <a href="/dashboard" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if request.path == '/dashboard' %}active{% endif %}">
                        <i class="fas fa-home w-5"></i>
                        <span class="font-medium">Dashboard</span>
                    </a>
                    
                    <a href="/dashboard/campaigns" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/campaigns' in request.path %}active{% endif %}">
                        <i class="fas fa-paper-plane w-5"></i>
                        <span class="font-medium">Campaigns</span>
                    </a>
                    
                    <a href="/dashboard/analytics" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/analytics' in request.path %}active{% endif %}">
                        <i class="fas fa-chart-line w-5"></i>
                        <span class="font-medium">Analytics</span>
                    </a>
                </div>
                
                <!-- Contacts Section -->
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Contacts</div>
                    
                    <a href="/dashboard/contacts" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/contacts' in request.path %}active{% endif %}">
                        <i class="fas fa-users w-5"></i>
                        <span class="font-medium">All Contacts</span>
                    </a>
                    
                    <a href="/dashboard/segments" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/segments' in request.path %}active{% endif %}">
                        <i class="fas fa-filter w-5"></i>
                        <span class="font-medium">Segments</span>
                    </a>
                </div>
                
                <!-- Configuration Section -->
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Configuration</div>
                    
                    <a href="/dashboard/domains" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/domains' in request.path %}active{% endif %}">
                        <i class="fas fa-globe w-5"></i>
                        <span class="font-medium">Domains</span>
                    </a>
                    
                    <a href="/dashboard/settings" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/settings' in request.path %}active{% endif %}">
                        <i class="fas fa-cog w-5"></i>
                        <span class="font-medium">Settings</span>
                    </a>
                </div>
                
                <!-- Advanced Section (Collapsible) -->
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Advanced</div>
                    
                    <a href="/dashboard/workflows" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/workflows' in request.path %}active{% endif %}">
                        <i class="fas fa-project-diagram w-5"></i>
                        <span class="font-medium">Workflows</span>
                        <span class="badge badge-new ml-auto">New</span>
                    </a>
                    
                    <a href="/dashboard/api-keys" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/api-keys' in request.path %}active{% endif %}">
                        <i class="fas fa-key w-5"></i>
                        <span class="font-medium">API Keys</span>
                    </a>
                    
                    <a href="/dashboard/integrations" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/integrations' in request.path %}active{% endif %}">
                        <i class="fas fa-puzzle-piece w-5"></i>
                        <span class="font-medium">Integrations</span>
                    </a>
                </div>
                
                <!-- Resources Section -->
                <div class="sidebar-group">
                    <div class="sidebar-group-title">Resources</div>
                    
                    <a href="/api/docs" target="_blank" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1">
                        <i class="fas fa-book w-5"></i>
                        <span class="font-medium">API Docs</span>
                        <i class="fas fa-external-link-alt text-xs ml-auto opacity-50"></i>
                    </a>
                    
                    <a href="/dashboard/team" class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-lg text-gray-700 mb-1 {% if '/team' in request.path %}active{% endif %}">
                        <i class="fas fa-user-friends w-5"></i>
                        <span class="font-medium">Team</span>
                    </a>
                </div>
                
            </nav>
            
            <!-- Bottom Section -->
            <div class="p-4 border-t border-gray-200 mt-auto">
                <!-- Upgrade Card -->
                <div class="bg-gradient-to-br from-purple-600 to-purple-800 rounded-xl p-4 mb-3">
                    <div class="text-white">
                        <div class="text-2xl mb-2">💎</div>
                        <h3 class="font-bold text-sm mb-1">Upgrade to Pro</h3>
                        <p class="text-xs opacity-90 mb-3">Unlock unlimited emails</p>
                        <a href="/pricing" class="block text-center bg-white text-purple-700 px-4 py-2 rounded-lg text-sm font-bold hover:bg-gray-100 transition">
                            Upgrade Now
                        </a>
                    </div>
                </div>
                
                <!-- User Profile -->
                <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer" onclick="toggleUserMenu()">
                    <div class="w-9 h-9 bg-purple-600 rounded-full flex items-center justify-center text-white font-bold">
                        {{ current_user.email[0].upper() if current_user else 'U' }}
                    </div>
                    <div class="flex-1">
                        <div class="text-sm font-semibold text-gray-900">{{ current_user.email.split('@')[0] if current_user else 'User' }}</div>
                        <div class="text-xs text-gray-500">Free Plan</div>
                    </div>
                    <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
                </div>
                
                <!-- User Dropdown Menu -->
                <div id="userMenu" class="hidden mt-2 bg-white border border-gray-200 rounded-lg shadow-lg">
                    <a href="/dashboard/settings/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                        <i class="fas fa-user mr-2"></i>Profile
                    </a>
                    <a href="/dashboard/settings/billing" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                        <i class="fas fa-credit-card mr-2"></i>Billing
                    </a>
                    <div class="border-t border-gray-200"></div>
                    <a href="/auth/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50">
                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                    </a>
                </div>
            </div>
            
        </aside>
        
        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto">
            
            <!-- Top Bar -->
            <header class="bg-white border-b border-gray-200 px-8 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900">{% block page_title %}Dashboard{% endblock %}</h2>
                        <p class="text-sm text-gray-600">{% block page_subtitle %}Welcome back!{% endblock %}</p>
                    </div>
                    
                    <div class="flex items-center gap-4">
                        <!-- Notifications -->
                        <button class="relative p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
                            <i class="fas fa-bell text-xl"></i>
                            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                        </button>
                        
                        <!-- Quick Actions -->
                        <a href="/dashboard/campaigns/create" class="flex items-center gap-2 bg-purple-600 text-white px-6 py-2.5 rounded-lg hover:bg-purple-700 transition font-semibold">
                            <i class="fas fa-plus"></i>
                            <span>New Campaign</span>
                        </a>
                    </div>
                </div>
            </header>
            
            <!-- Page Content -->
            <div class="p-8">
                {% with messages = get_flashed_messages(with_categories=true) %}
                    {% if messages %}
                        {% for category, message in messages %}
                            <div class="mb-4 p-4 rounded-lg {% if category == 'error' %}bg-red-50 text-red-800 border border-red-200{% else %}bg-green-50 text-green-800 border border-green-200{% endif %}">
                                {{ message }}
                            </div>
                        {% endfor %}
                    {% endif %}
                {% endwith %}
                
                {% block content %}{% endblock %}
            </div>
            
        </main>
        
    </div>
    
    <script>
        // Toggle user menu
        function toggleUserMenu() {
            const menu = document.getElementById('userMenu');
            menu.classList.toggle('hidden');
        }
        
        // Close menu when clicking outside
        document.addEventListener('click', function(event) {
            const menu = document.getElementById('userMenu');
            const trigger = event.target.closest('[onclick="toggleUserMenu()"]');
            if (!trigger && !menu.contains(event.target)) {
                menu.classList.add('hidden');
            }
        });
    </script>
    
    {% block extra_js %}{% endblock %}
</body>
</html>
